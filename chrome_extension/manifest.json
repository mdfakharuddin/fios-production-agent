{
  "manifest_version": 3,
  "name": "Upie Intelligence",
  "version": "2.1",
  "description": "Upie — Strategic AI Advisor for Upwork Decision Intelligence.",
  "icons": {
    "16": "icons/icon_16.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://*.upwork.com/*",
    "https://api.themenuagency.com/fios/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon_16.png",
      "48": "icons/icon_48.png",
      "128": "icons/icon_128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.upwork.com/*"],
      "js": [
        "content_scripts/scraper.js",
        "content_scripts/upie_scraper.js",
        "content_scripts/floating_ui.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content_scripts/floating_ui.css",
        "icons/*.png"
      ],
      "matches": ["https://*.upwork.com/*"]
    }
  ]
}
